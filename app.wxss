/* app.wxss - 全局样式 - 渐变美化版 */

/* 主题色 - 渐变色系 */
page {
  /* 字号规范（4档，相邻约1.2倍比例） */
  --font-xs: 22rpx;   /* 标签、角标、次要说明 */
  --font-sm: 26rpx;   /* 正文、列表内容、描述文字 */
  --font-md: 30rpx;   /* 卡片标题、区块名 */
  --font-lg: 36rpx;   /* 页面主标题、Banner */

  /* 主色调渐变 */
  --primary: #667eea;
  --primary-end: #764ba2;
  --primary-light: #8b9ff8;
  
  /* 辅助色渐变 */
  --secondary: #f093fb;
  --secondary-end: #f5576c;
  
  /* 成功色渐变 */
  --success: #43e97b;
  --success-end: #38f9d7;
  
  /* 警告色渐变 */
  --warning: #ff9a44;
  --warning-end: #fc6076;
  
  /* 危险色渐变 */
  --danger: #ff6b6b;
  --danger-end: #ee5a5a;
  
  /* 信息色 */
  --info: #4facfe;
  --info-end: #00f2fe;
  
  /* 背景色 */
  --bg-color: #f5f5f5;
  --bg-gradient: linear-gradient(180deg, #f8f9ff 0%, #f0f2ff 100%);
  --card-bg: #FFFFFF;
  
  /* 文字颜色 */
  --text-primary: #303133;
  --text-regular: #606266;
  --text-secondary: #909399;
  --text-placeholder: #C0C4CC;
  
  /* 边框和圆角 */
  --border-color: #EBEEF5;
  --border-radius: 16rpx;
  --shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.1);
  --shadow-lg: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  
  background: var(--bg-gradient);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-end) 100%);
}

.gradient-bg-soft {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
}

/* 通用容器 */
.container {
  padding: 24rpx 32rpx;
  padding-bottom: 180rpx;
  background: var(--bg-gradient);
  min-height: 100vh;
}

/* 卡片样式 - 渐变边框效果 */
.card {
  background: var(--card-bg);
  border-radius: var(--border-radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
  position: relative;
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary), var(--secondary), var(--info));
  border-radius: var(--border-radius) var(--border-radius) 0 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.card-title .icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* 标签样式 - 渐变效果 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary { 
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15)); 
  color: var(--primary);
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}
.tag-success { 
  background: linear-gradient(135deg, rgba(67, 233, 123, 0.15), rgba(56, 249, 215, 0.15)); 
  color: #2dbd6e;
  border: 1rpx solid rgba(67, 233, 123, 0.2);
}
.tag-warning { 
  background: linear-gradient(135deg, rgba(255, 154, 68, 0.15), rgba(252, 96, 118, 0.15)); 
  color: #e8823a;
  border: 1rpx solid rgba(255, 154, 68, 0.2);
}
.tag-danger { 
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.15), rgba(238, 90, 90, 0.15)); 
  color: var(--danger);
  border: 1rpx solid rgba(255, 107, 107, 0.2);
}
.tag-info { 
  background: linear-gradient(135deg, rgba(79, 172, 254, 0.15), rgba(0, 242, 254, 0.15)); 
  color: var(--info);
  border: 1rpx solid rgba(79, 172, 254, 0.2);
}

/* 按钮样式 - 渐变按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-end) 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: linear-gradient(135deg, var(--secondary) 0%, var(--secondary-end) 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(240, 147, 251, 0.3);
  transition: all 0.3s ease;
}

.btn-secondary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 44rpx;
  padding: 18rpx 48rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn-outline::after {
  border: none;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  transition: all 0.2s;
}

.list-item:active {
  background: rgba(102, 126, 234, 0.05);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item .arrow {
  margin-left: auto;
  color: var(--text-placeholder);
  font-size: 28rpx;
}

/* 进度条 - 渐变填充 */
.progress-bar {
  height: 12rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar .fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary), var(--info));
  background-size: 200% 100%;
  animation: gradientMove 3s ease infinite;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

@keyframes gradientMove {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-state .text {
  color: var(--text-secondary);
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  margin: 24rpx 0;
}

/* flex布局 */
.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* 文字省略 */
.ellipsis { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.ellipsis-3 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 3; overflow: hidden; }

/* 通用渐变文字效果 */
.gradient-text {
  background: linear-gradient(135deg, var(--primary), var(--secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 通用渐变边框效果 */
.gradient-border {
  position: relative;
  background: #fff;
}

.gradient-border::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: inherit;
  padding: 2rpx;
  background: linear-gradient(135deg, var(--primary), var(--secondary), var(--info));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

/* 浮动动画 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.float-animation {
  animation: float 3s ease-in-out infinite;
}

/* 脉冲动画 */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.pulse-animation {
  animation: pulse 2s ease-in-out infinite;
}

/* 渐变背景动画 */
@keyframes bgShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.gradient-animate {
  background-size: 200% 200%;
  animation: bgShift 4s ease infinite;
}
