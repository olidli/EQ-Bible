    "content": {
      "type": "article",
      "summary": "好的决策来自清晰的思维框架，而非完美的信息或运气。",
      "read_time": "5分钟",
      "difficulty": "进阶",
      "source": "决策心理学研究",
      "core_concepts": [
        "决策框架",
        "机会成本",
        "满意原则",
