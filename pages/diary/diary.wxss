/* pages/diary/diary.wxss - 情绪日记页重构版 */

.container {
  padding-bottom: 60rpx;
  background: linear-gradient(180deg, #f8f9ff 0%, #f0f2ff 50%, #f5f5f5 100%);
  min-height: 100vh;
}

/* 顶部标题区 */
.header {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  padding: 48rpx 28rpx 40rpx;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(240, 147, 251, 0.25);
  margin-bottom: 0;
}

.header-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.header-title-wrap {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.header-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 新建按钮 */
.new-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  min-width: 80rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  transition: all 0.2s;
}
.new-btn:active {
  background: rgba(255, 255, 255, 0.35);
  transform: scale(0.96);
}
.new-btn-icon {
  font-size: 36rpx;
  font-weight: 300;
  color: #fff;
  line-height: 1;
}
.new-btn-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 6rpx;
}

/* 统计卡片行 */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-top: 4rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 16rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.stat-card-accent {
  background: rgba(255, 255, 255, 0.3);
  border-color: rgba(255, 255, 255, 0.4);
}

.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 4rpx;
}

/* 日记列表 */
.diary-list {
  padding: 24rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 日记卡片 */
.diary-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx 24rpx 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
  transition: all 0.2s;
}

.diary-item:active {
  transform: scale(0.99);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
}

/* 彩色左边框 */
.diary-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 8rpx;
  height: 100%;
  background: var(--accent-color, #667eea);
  border-radius: 16rpx 0 0 16rpx;
}

/* 顶部行 */
.item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.item-emotion {
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
}

.item-date {
  font-size: 22rpx;
  color: #999;
}

/* 情绪强度进度条 */
.intensity-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.intensity-bar-wrap {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.intensity-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.intensity-label {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
}

/* 内容预览 */
.item-preview {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx 60rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
  text-align: center;
  line-height: 1.6;
}

.empty-btn {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: #fff;
  border-radius: 44rpx;
  padding: 20rpx 56rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 20rpx rgba(240, 147, 251, 0.3);
  transition: all 0.3s ease;
}

.empty-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(240, 147, 251, 0.2);
}
