/* pages/test/test.wxss - 测评页渐变美化版 */

.container {
  padding: 30rpx;
  background: linear-gradient(180deg, #f8f9ff 0%, #f0f2ff 50%, #f5f5f5 100%);
  min-height: 100vh;
}

/* 进度条 - 渐变动画 */
.progress-bar-wrap {
  height: 8rpx;
  background: rgba(102, 126, 234, 0.15);
  border-radius: 4rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
  background-size: 200% 100%;
  animation: gradientShift 2s ease infinite;
  border-radius: 4rpx;
  transition: width 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

@keyframes gradientShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  display: block;
  text-align: center;
  margin-bottom: 30rpx;
}

/* 题目卡片 - 玻璃态效果 */
.question-card {
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.12);
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.question-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
}

.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 40rpx;
}

/* 选项 - 渐变选择效果 */
.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  border-radius: 16rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.1);
  transition: all 0.3s ease;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.selected {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-color: transparent;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
}

.option-label {
  font-size: 28rpx;
  color: #333;
}

.option-item.selected .option-label {
  color: #fff;
}

/* 下一题按钮 - 渐变按钮 */
.next-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.next-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(102, 126, 234, 0.2);
}

/* 结果面板 - 渐变背景 */
.result-panel {
  text-align: center;
  padding-top: 40rpx;
}

.result-header {
  margin-bottom: 40rpx;
}

.result-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 20rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15rpx); }
}

.result-level {
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea, #764ba2, #f093fb);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  margin-bottom: 10rpx;
}

.result-score {
  font-size: 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  font-weight: 600;
}

/* 结果描述和建议 - 渐变边框卡片 */
.result-desc, .result-advice {
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  text-align: left;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(102, 126, 234, 0.08);
}

.result-desc::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2);
}

.result-desc text, .result-advice text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.advice-title {
  font-weight: 600;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  margin-bottom: 10rpx;
  font-size: 30rpx;
}

/* 结果操作按钮 */
.result-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.restart-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.restart-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(102, 126, 234, 0.2);
}

.back-btn {
  flex: 1;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.back-btn:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
}
