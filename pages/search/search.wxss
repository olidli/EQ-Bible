/* pages/search/search.wxss - 搜索页渐变美化版 */

.container {
  padding: 20rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #f8f9ff 0%, #f0f2ff 50%, #f5f5f5 100%);
  min-height: 100vh;
}

/* 搜索头部 - 玻璃态效果 */
.search-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  font-size: 28rpx;
  color: #ccc;
  padding: 0 8rpx;
}

.search-btn {
  font-size: 28rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 600;
  margin-left: 20rpx;
}

/* 通用区域 - 玻璃态卡片 */
.section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(102, 126, 234, 0.08);
  position: relative;
  overflow: hidden;
}

.section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 20rpx;
  display: block;
}

/* 热门标签 - 渐变标签 */
.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-tag {
  font-size: 26rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  color: #667eea;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  transition: all 0.3s ease;
}

.hot-tag:active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  transform: scale(0.98);
}

/* 搜索结果头部 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-count {
  font-size: 28rpx;
  color: #666;
}

.result-filter {
  font-size: 26rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 500;
}

/* 结果列表 - 渐变标签效果 */
.result-list {
  display: flex;
  flex-direction: column;
}

.result-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.08);
  transition: all 0.2s;
  border-radius: 12rpx;
}

.result-item:last-child {
  border-bottom: none;
}

.result-item:active {
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.05), transparent);
  padding-left: 12rpx;
}

.result-type-badge {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.result-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.result-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  line-height: 1.5;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.result-tag {
  font-size: 22rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  color: #667eea;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
}

/* 空状态 - 渐变装饰 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

/* 结果项顶部行（类型 + 状态标记） */
.item-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

/* 已学 / 已收藏状态标记 */
.item-status-badge {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.status-learned {
  background: rgba(102, 126, 234, 0.15);
  color: #667eea;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.status-fav {
  background: rgba(255, 107, 107, 0.12);
  color: #ff6b6b;
  border: 1rpx solid rgba(255, 107, 107, 0.2);
}

/* 筛选 Tab 栏 */
.filter-tabs {
  display: flex;
  white-space: nowrap;
  padding: 12rpx 0 8rpx;
  margin-bottom: 4rpx;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  font-size: 26rpx;
  color: #888;
  padding: 10rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
  background: #fff;
  white-space: nowrap;
  flex-shrink: 0;
}

.filter-tab-active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-color: transparent;
}

.result-count-bar {
  padding: 0 4rpx 12rpx;
}

.result-count {
  font-size: 24rpx;
  color: #999;
}

/* 筛选数量提示 */
.filter-hint {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}


.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}
