<!-- pages/search/search.wxml -->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-header">
    <view class="search-input-wrap">
      <image class="search-icon" src="/images/search.png" mode="aspectFit"/>
      <input
        class="search-input"
        placeholder="搜索知识、工具、书籍..."
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="doSearch"
        focus="{{true}}"
        confirm-type="search"/>
      <text class="search-clear" wx:if="{{keyword}}" bindtap="clearKeyword">✕</text>
    </view>
    <text class="search-btn" bindtap="doSearch">搜索</text>
  </view>

  <!-- 热门标签（未搜索时显示） -->
  <view class="section" wx:if="{{!hasSearched}}">
    <view class="section-title">🔥 热门搜索</view>
    <view class="hot-tags">
      <text
        class="hot-tag"
        wx:for="{{hotTags}}"
        wx:key="text"
        style="background: {{item.bg}}; color: {{item.color}}; border-color: {{item.border}};"
        bindtap="quickSearch"
        data-keyword="{{item.text}}">{{item.text}}</text>
    </view>
  </view>

  <!-- 搜索结果区 -->
  <view wx:if="{{hasSearched}}">
    <!-- 筛选 Tab 栏 -->
    <scroll-view class="filter-tabs" scroll-x enable-flex>
      <view
        class="filter-tab {{currentFilter === 'all' ? 'filter-tab-active' : ''}}"
        bindtap="switchFilter" data-key="all" data-label="全部">全部</view>
      <view
        class="filter-tab {{currentFilter === 'article' ? 'filter-tab-active' : ''}}"
        bindtap="switchFilter" data-key="article" data-label="文章">文章</view>
      <view
        class="filter-tab {{currentFilter === 'book' ? 'filter-tab-active' : ''}}"
        bindtap="switchFilter" data-key="book" data-label="书籍摘要">书摘</view>
      <view
        class="filter-tab {{currentFilter === 'card' ? 'filter-tab-active' : ''}}"
        bindtap="switchFilter" data-key="card" data-label="技巧卡片">卡片</view>
      <view
        class="filter-tab {{currentFilter === 'fav' ? 'filter-tab-active' : ''}}"
        bindtap="switchFilter" data-key="fav" data-label="我的收藏">❤ 收藏</view>
      <view
        class="filter-tab {{currentFilter === 'learned' ? 'filter-tab-active' : ''}}"
        bindtap="switchFilter" data-key="learned" data-label="已学习">已学</view>
    </scroll-view>

    <!-- 结果数量 -->
    <view class="result-count-bar">
      <text class="result-count">共 {{results.length}} 条结果</text>
    </view>

    <!-- 结果列表 -->
    <view class="section">
      <view class="result-list" wx:if="{{results.length > 0}}">
        <view
          class="result-item"
          wx:for="{{results}}"
          wx:key="_id"
          bindtap="goDetail"
          data-id="{{item._id}}">
          <view class="item-top">
            <view class="item-status-badge status-learned" wx:if="{{item.isLearned}}">已学</view>
            <view class="item-status-badge status-fav" wx:if="{{item.isFav}}">❤ 收藏</view>
          </view>
          <text class="result-title">{{item.title}}</text>
          <view class="result-tags" wx:if="{{item.tags.length > 0}}">
            <text
              class="result-tag"
              wx:for="{{item.tags}}"
              wx:for-item="tag"
              wx:key="*this"
              wx:if="{{index < 3}}">{{tag}}</text>
          </view>
        </view>
      </view>

      <view class="empty" wx:else>
        <text class="empty-icon">🔍</text>
        <text class="empty-text">没有找到相关内容</text>
        <text class="empty-hint" wx:if="{{currentFilter !== 'all'}}">试试「全部」看看</text>
        <text class="empty-hint" wx:else>换个关键词试试？</text>
      </view>
    </view>
  </view>
</view>
