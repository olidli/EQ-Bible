.container {
  padding: 30rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  min-height: 100vh;
}

.rank-title {
  text-align: center;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

/* 前三名 */
.top-three {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 20rpx 0 40rpx;
  gap: 20rpx;
}

.top-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.top-item.first {
  order: 2;
}

.top-item.second {
  order: 1;
}

.top-item.third {
  order: 3;
}

.top-avatar-wrap {
  position: relative;
  margin-bottom: 10rpx;
}

.top-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #4ecdc4;
}

.top-avatar.big {
  width: 120rpx;
  height: 120rpx;
  border-color: #ffe66d;
}

.top-crown {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 32rpx;
}

.top-name {
  color: #fff;
  font-size: 24rpx;
  margin-bottom: 4rpx;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-score {
  color: #4ecdc4;
  font-size: 22rpx;
}

/* 排行列表 */
.rank-list {
  margin-bottom: 120rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #1f2940;
}

.rank-num {
  width: 60rpx;
  text-align: center;
  color: #8892b0;
  font-size: 28rpx;
}

.rank-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin: 0 20rpx;
}

.rank-info {
  flex: 1;
}

.rank-name {
  color: #e6f1ff;
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.rank-level {
  color: #8892b0;
  font-size: 22rpx;
}

.rank-score {
  color: #4ecdc4;
  font-size: 28rpx;
  font-weight: bold;
}

/* 我的排名 */
.my-rank {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #1f2940;
  border-top: 2rpx solid #2a3a5a;
}

.my-rank-num {
  width: 100rpx;
  color: #ffe66d;
  font-size: 28rpx;
  font-weight: bold;
}

.my-rank-info {
  flex: 1;
}

.my-rank-name {
  color: #fff;
  font-size: 28rpx;
  margin-right: 12rpx;
}

.my-rank-level {
  color: #8892b0;
  font-size: 22rpx;
}

.my-rank-score {
  color: #4ecdc4;
  font-size: 32rpx;
  font-weight: bold;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #8892b0;
  font-size: 28rpx;
  margin-bottom: 30rpx;
}

.empty-btn {
  display: inline-block;
  background: linear-gradient(135deg, #4ecdc4, #44a8e8);
  color: #1a1a2e;
  font-size: 28rpx;
  font-weight: bold;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
}
