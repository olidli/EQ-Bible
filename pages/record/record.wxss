/* pages/record/record.wxss */
.container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #303133;
  flex: 1;
}

.count {
  font-size: 24rpx;
  color: #909399;
  margin-right: 20rpx;
}

.clear-btn {
  font-size: 24rpx;
  color: #f56c6c;
  padding: 8rpx 16rpx;
  border: 1rpx solid #f56c6c;
  border-radius: 20rpx;
}

.list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.item:last-child {
  border-bottom: none;
}

.item:active {
  background: #f5f5f5;
}

.item-type {
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-title {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-arrow {
  font-size: 28rpx;
  color: #c0c4cc;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #909399;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #c0c4cc;
}
