/* pages/index/index.wxss - 首页重构版 */

.container {
  padding-bottom: 30rpx;
  background: linear-gradient(180deg, #f8f9ff 0%, #f0f2ff 50%, #f5f5f5 100%);
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  margin: 20rpx 24rpx;
  padding: 18rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.1);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}
.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}
.search-placeholder {
  font-size: 26rpx;
  color: #999;
}

/* 今日打卡卡片 */
.today-card {
  margin: 0 24rpx 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 28rpx 28rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
  color: #fff;
}
.today-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.today-left {
  display: flex;
  flex-direction: column;
}
.today-greeting {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.today-stats {
  font-size: 22rpx;
  opacity: 0.85;
}
.today-pct {
  display: flex;
  align-items: flex-end;
}
.today-pct-num {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}
.today-pct-sym {
  font-size: 22rpx;
  opacity: 0.8;
  margin-bottom: 6rpx;
  margin-left: 4rpx;
}
.today-progress-wrap {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.today-progress-fill {
  height: 100%;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 4rpx;
  transition: width 0.6s ease;
}
.today-recommend {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.today-rec-label {
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
.today-rec-title {
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 情绪急救箱入口卡片 */
.emergency-entry {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.3);
}

.emergency-entry:active {
  transform: scale(0.98);
}

.emergency-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.emergency-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.emergency-icon {
  font-size: 40rpx;
}

.emergency-info {
  flex: 1;
}

.emergency-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.emergency-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.emergency-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
}

.emergency-tools {
  display: flex;
  gap: 16rpx;
}

.tool-tag {
  font-size: 22rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 通用区块 */
.section {
  margin: 0 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(102, 126, 234, 0.08);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.section-more {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 500;
}

/* 核心模块网格（3列×3行，flex兼容旧版微信） */
.module-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.module-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  border-radius: 16rpx;
  flex: 0 0 calc(33.33% - 12rpx);
  box-sizing: border-box;
  border: 1rpx solid rgba(102, 126, 234, 0.08);
  transition: all 0.3s ease;
}
.module-item:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
}
.module-hover {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15));
  transform: scale(0.98);
}
.module-item-all .module-icon {
  background: linear-gradient(135deg, #888, #555) !important;
}
.module-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  margin-bottom: 10rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}
.module-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  text-align: center;
}
.module-count {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 快捷工具横向滑动 */
.tool-scroll {
  display: flex;
  white-space: nowrap;
  padding-bottom: 4rpx;
}
.tool-capsule {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 20rpx;
  padding: 20rpx 28rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.08));
  border-radius: 20rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  min-width: 120rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}
.tool-capsule:last-child {
  margin-right: 0;
}
.tool-capsule:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15));
}
.tool-cap-emoji {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}
.tool-cap-name {
  font-size: 22rpx;
  color: #555;
  font-weight: 500;
  white-space: nowrap;
}

/* 每日推荐 */
.recommend-list {
  display: flex;
  flex-direction: column;
}
.recommend-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.08);
  transition: all 0.2s;
}
.recommend-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}
.recommend-item:active {
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.05), transparent);
  padding-left: 12rpx;
}
.recommend-type {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}
.recommend-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}
.recommend-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.recommend-tag {
  font-size: 22rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  color: #667eea;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
}
.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 社死模拟器 Hero Banner */
.game-hero {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #6c5ce7 0%, #e84393 50%, #fd79a8 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(108, 92, 231, 0.35);
  position: relative;
  overflow: hidden;
}
.game-hero::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}
.game-hero::after {
  content: '';
  position: absolute;
  bottom: -60rpx;
  left: -20rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}
.game-hero:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}
.game-hero-top {
  position: relative;
  z-index: 1;
}
.game-hero-badge {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 800;
  color: #6c5ce7;
  background: rgba(255, 255, 255, 0.95);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}
.game-hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}
.game-hero-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 24rpx;
}
.game-hero-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}
.game-hero-tag {
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  font-weight: 500;
}
.game-hero-tag.tag-campus { background: rgba(116, 185, 255, 0.5); }
.game-hero-tag.tag-family { background: rgba(255, 118, 117, 0.5); }
.game-hero-tag.tag-dating { background: rgba(253, 121, 168, 0.5); }
.game-hero-tag.tag-wechat { background: rgba(162, 155, 254, 0.5); }
.game-hero-tag.tag-relative { background: rgba(253, 203, 110, 0.5); }
.game-hero-cta {
  position: relative;
  z-index: 1;
}
.game-hero-btn {
  display: inline-block;
  font-size: 28rpx;
  font-weight: 700;
  color: #6c5ce7;
  background: rgba(255, 255, 255, 0.95);
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}
