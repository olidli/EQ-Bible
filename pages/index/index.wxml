<!-- pages/index/index.wxml -->
<!-- EQ情商宝典首页 -->
<view class="container">
  <!-- 顶部搜索栏 -->
  <view class="search-bar" bindtap="goSearch">
    <image class="search-icon" src="/images/search.png" mode="aspectFit"/>
    <text class="search-placeholder">搜索情商知识、工具、技巧...</text>
  </view>

  <!-- 每日情商小课堂（沉浸式深色卡片） -->
  <view class="daily-card-wrap" wx:if="{{dailyCard}}">
    <view class="daily-card">
      <view class="daily-card-inner">
        <!-- 背景装饰圆环 -->
        <view class="daily-card-glow"></view>
        <view class="daily-card-ring"></view>

        <!-- 顶部：日期日历样式 + 标签 -->
        <view class="daily-card-header">
          <view class="daily-calendar">
            <text class="daily-cal-month">{{dailyCard.month}}</text>
            <text class="daily-cal-day">{{dailyCard.day}}</text>
          </view>
          <view class="daily-card-meta">
            <text class="daily-meta-label">每日小课堂</text>
            <text class="daily-meta-no" wx:if="{{dailyCard.no}}">NO.{{dailyCard.no}}</text>
          </view>
        </view>

        <!-- 中间：艺术引号 + 金句 -->
        <view class="daily-card-quote">
          <text class="daily-quote-mark">"</text>
          <text class="daily-quote-text">{{dailyCard.quote}}</text>
        </view>

        <!-- 底部：来源 + 订阅按钮 + 装饰线 -->
        <view class="daily-card-footer" wx:if="{{dailyCard.source || !subscribed}}">
          <view class="daily-footer-line"></view>
          <text class="daily-source" wx:if="{{dailyCard.source}}">{{dailyCard.source}}</text>
          <view class="daily-subscribe-btn" bindtap="subscribeDaily" wx:if="{{!subscribed}}">
            <text class="daily-sub-icon">🔔</text>
            <text class="daily-sub-text">订阅提醒</text>
          </view>
          <view class="daily-subscribe-btn subscribed" wx:if="{{subscribed}}">
            <text class="daily-sub-icon">✅</text>
            <text class="daily-sub-text">已订阅</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 社死模拟器 Hero Banner -->
  <view class="game-hero" bindtap="goGame">
    <view class="game-hero-top">
      <view class="game-hero-badge">HOT</view>
      <text class="game-hero-title">社死模拟器</text>
      <text class="game-hero-sub">100个名场面 · 你能活过几关？</text>
    </view>
    <view class="game-hero-tags">
      <text class="game-hero-tag tag-campus">校园</text>
      <text class="game-hero-tag tag-family">家庭</text>
      <text class="game-hero-tag tag-dating">恋爱</text>
      <text class="game-hero-tag tag-wechat">群聊</text>
      <text class="game-hero-tag tag-relative">亲戚</text>
    </view>
    <view class="game-hero-cta">
      <text class="game-hero-btn">立即挑战 ›</text>
    </view>
  </view>

  <!-- 情绪急救箱入口卡片 -->
  <view class="emergency-entry" bindtap="goEmotionFirstAid">
    <view class="emergency-header">
      <view class="emergency-icon-wrap">
        <text class="emergency-icon">🆘</text>
      </view>
      <view class="emergency-info">
        <text class="emergency-title">情绪急救箱</text>
        <text class="emergency-desc">快速缓解负面情绪</text>
      </view>
      <text class="emergency-arrow">›</text>
    </view>
  </view>

  <!-- 核心模块入口（3列×3行，更宽松） -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🎯 知识模块</text>
    </view>
    <view class="module-grid">
      <view class="module-item" bindtap="goCategory" data-id="self_aware" hover-class="module-hover" hover-start-time="0" hover-stay-time="200">
        <view class="module-icon" style="background: #667eea;">🧠</view>
        <text class="module-name">自我认知</text>
        <text class="module-count">{{moduleCounts.self_aware}}篇</text>
      </view>
      <view class="module-item" bindtap="goCategory" data-id="emotion" hover-class="module-hover" hover-start-time="0" hover-stay-time="200">
        <view class="module-icon" style="background: #f093fb;">😊</view>
        <text class="module-name">情绪管理</text>
        <text class="module-count">{{moduleCounts.emotion}}篇</text>
      </view>
      <view class="module-item" bindtap="goCategory" data-id="communication" hover-class="module-hover" hover-start-time="0" hover-stay-time="200">
        <view class="module-icon" style="background: #4facfe;">💬</view>
        <text class="module-name">沟通表达</text>
        <text class="module-count">{{moduleCounts.communication}}篇</text>
      </view>
      <view class="module-item" bindtap="goCategory" data-id="relation" hover-class="module-hover" hover-start-time="0" hover-stay-time="200">
        <view class="module-icon" style="background: #f5576c;">🤝</view>
        <text class="module-name">人际关系</text>
        <text class="module-count">{{moduleCounts.relation}}篇</text>
      </view>
      <view class="module-item" bindtap="goCategory" data-id="growth" hover-class="module-hover" hover-start-time="0" hover-stay-time="200">
        <view class="module-icon" style="background: #96ceb4;">🌱</view>
        <text class="module-name">个人成长</text>
        <text class="module-count">{{moduleCounts.growth}}篇</text>
      </view>
      <!-- 全部模块入口 -->
      <view class="module-item module-item-all" bindtap="goTools" hover-class="module-hover" hover-start-time="0" hover-stay-time="200">
        <view class="module-icon" style="background: #888;">⚡</view>
        <text class="module-name">全部工具</text>
        <text class="module-count">{{toolCount}}个</text>
      </view>
    </view>
  </view>


  <!-- 快捷工具（横向滑动胶囊） -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">⚡ 常用工具</text>
      <text class="section-more" bindtap="goTools">全部 ›</text>
    </view>
    <scroll-view class="tool-scroll" scroll-x enable-flex>
      <view class="tool-capsule" bindtap="openTool" data-tool="emotion_diary">
        <text class="tool-cap-emoji">📝</text>
        <text class="tool-cap-name">情绪日记</text>
      </view>
      <view class="tool-capsule" bindtap="openTool" data-tool="emotion_recognition">
        <text class="tool-cap-emoji">🎭</text>
        <text class="tool-cap-name">情绪识别</text>
      </view>
      <view class="tool-capsule" bindtap="openTool" data-tool="ability_assess">
        <text class="tool-cap-emoji">📊</text>
        <text class="tool-cap-name">能力测评</text>
      </view>
    </scroll-view>
  </view>

  <!-- 每日推荐（最多显示3条） -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">📖 更多推荐</text>
      <text class="section-more" bindtap="goRecommend">换一批</text>
    </view>
    <view class="recommend-list" wx:if="{{dailyItems.length > 1}}">
      <view class="recommend-item" wx:for="{{dailyItems}}" wx:key="id"
        wx:if="{{index > 0 && index < 4}}"
        bindtap="goDetail" data-id="{{item.id}}">
        <text class="recommend-title">{{item.title}}</text>
        <view class="recommend-tags" wx:if="{{item.tags && item.tags.length > 0}}">
          <text class="recommend-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text>加载中...</text>
    </view>
  </view>
</view>
