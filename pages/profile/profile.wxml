<!-- pages/profile/profile.wxml -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-card">
    <view class="user-avatar">
      <text class="avatar-emoji">🧠</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '情商学习者'}}</text>
      <text class="user-level">已学 {{learnedCount}} 篇</text>
    </view>
    <view class="user-stats">
      <view class="stat-item">
        <text class="stat-num">{{learnedCount}}</text>
        <text class="stat-label">已学</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{favCount}}</text>
        <text class="stat-label">收藏</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{diaryCount}}</text>
        <text class="stat-label">日记</text>
      </view>
    </view>
  </view>

  <!-- 学习进度 -->
  <view class="progress-card">
    <text class="card-title">📈 学习进度</text>
    <view class="progress-bar-wrap">
      <view class="progress-bar" style="width: {{progress}}%;"></view>
    </view>
    <view class="progress-info">
      <text>共 {{totalItems}} 项内容</text>
      <text>已完成 {{progress}}%</text>
    </view>
    <view class="progress-modules">
      <view class="progress-module" wx:for="{{moduleProgress}}" wx:key="name">
        <text class="module-name">{{item.name}}</text>
        <text class="module-pct">{{item.pct}}%</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goPage" data-page="favorites">
      <text class="menu-icon">❤️</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-page="diary">
      <text class="menu-icon">📝</text>
      <text class="menu-text">情绪日记</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-page="progress">
      <text class="menu-icon">📊</text>
      <text class="menu-text">学习记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-page="tests">
      <text class="menu-icon">📋</text>
      <text class="menu-text">能力测评</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="about-section">
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于EQ情商宝典</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPrivacy">
      <text class="menu-icon">🔒</text>
      <text class="menu-text">隐私保护指引</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="contact">
      <text class="menu-icon">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <text class="version">EQ情商宝典 v1.0.7 | {{totalItems}}项知识库</text>
</view>
