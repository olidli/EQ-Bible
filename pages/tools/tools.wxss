/* pages/tools/tools.wxss - 工具页渐变美化版 */

.container {
  padding: 20rpx 24rpx 40rpx;
  background: linear-gradient(180deg, #f8f9ff 0%, #f0f2ff 50%, #f5f5f5 100%);
  min-height: 100vh;
}

/* ===== 工具选择区 ===== */
.tool-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.tool-select-title {
  font-size: 34rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.view-toggle {
  width: 72rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.1);
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.toggle-icon {
  font-size: 32rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* --- 列表模式 --- */
.tool-list-view {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tool-list-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.06);
  transition: all 0.3s ease;
  border: 1rpx solid rgba(102, 126, 234, 0.06);
}

.tool-list-item.active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.08));
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.15);
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.tool-list-item:active {
  transform: scale(0.98);
}

.tool-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tool-icon-emoji {
  font-size: 40rpx;
}

.tool-list-info {
  flex: 1;
  min-width: 0;
}

.tool-list-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 4rpx;
}

.tool-list-desc {
  font-size: 22rpx;
  color: #909399;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-arrow {
  font-size: 36rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* --- 网格模式 --- */
.tool-grid-view {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tool-grid-card {
  width: calc(50% - 10rpx);
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.06);
  transition: all 0.3s ease;
  border: 1rpx solid rgba(102, 126, 234, 0.06);
}

.tool-grid-card.active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.08));
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.15);
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.tool-grid-card:active {
  transform: scale(0.98);
}

.tool-grid-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tool-grid-emoji {
  font-size: 36rpx;
}

.tool-grid-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 4rpx;
}

.tool-grid-desc {
  font-size: 22rpx;
  color: #909399;
  display: block;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 工具面板 - 渐变边框效果 ===== */
.tool-panel {
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 0;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
  overflow: hidden;
  position: relative;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.tool-panel::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 0;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #303133;
}

.panel-close {
  font-size: 32rpx;
  color: #909399;
  padding: 8rpx 16rpx;
}

.panel-body {
  padding: 24rpx 28rpx 28rpx;
}

/* ===== 表单通用 ===== */
.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #606266;
  display: block;
  margin-bottom: 12rpx;
}

.form-value {
  font-size: 28rpx;
  color: #303133;
}

.form-textarea {
  width: 100%;
  height: 140rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  color: #303133;
  box-sizing: border-box;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.form-textarea:focus {
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.form-textarea.tall {
  height: 200rpx;
}

/* ===== 按钮 - 渐变按钮 ===== */
.save-btn {
  width: 100%;
  height: 88rpx;
  background: #4A90D9;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  border: none;
  line-height: 88rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}

.save-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.save-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}

.save-btn::after {
  border: none;
}

/* ===== 情绪选择器 - 渐变效果 ===== */
.emotion-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.emotion-option {
  font-size: 26rpx;
  color: #606266;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.08));
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.emotion-option.selected {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

/* ===== 情绪分析 - 渐变结果框 ===== */
.recognition-tip {
  font-size: 26rpx;
  color: #909399;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.analysis-result {
  background: linear-gradient(135deg, rgba(67, 233, 123, 0.1), rgba(56, 249, 215, 0.1));
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
  border: 1rpx solid rgba(67, 233, 123, 0.2);
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2dbd6e;
  display: block;
  margin-bottom: 12rpx;
}

.result-text {
  font-size: 26rpx;
  color: #303133;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* ===== 学习路径 - 渐变步骤 ===== */
.goal-tags,
.time-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.goal-tag,
.time-tag {
  font-size: 26rpx;
  color: #606266;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.08));
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.goal-tag.selected,
.time-tag.selected {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.path-result {
  margin-top: 24rpx;
}

.path-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.path-item {
  position: relative;
  padding-left: 40rpx;
}

.path-step {
  display: flex;
  align-items: flex-start;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.step-content {
  flex: 1;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  border-radius: 14rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.08);
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 6rpx;
}

.step-desc {
  font-size: 24rpx;
  color: #909399;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.step-duration {
  font-size: 22rpx;
  color: #667eea;
}

/* ===== 历史记录 - 渐变卡片 ===== */
.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin: 32rpx 0 16rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.08);
  transition: all 0.2s;
}

.history-item:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
}

.history-date {
  font-size: 22rpx;
  color: #909399;
  display: block;
}

.history-emotion {
  font-size: 26rpx;
  color: #303133;
  font-weight: 600;
  display: block;
  margin: 4rpx 0;
}

.history-trigger {
  font-size: 24rpx;
  color: #606266;
  display: block;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 工具通用面板 ===== */
.tool-intro {
  font-size: 26rpx;
  color: #909399;
  line-height: 1.6;
  display: block;
  margin-bottom: 24rpx;
}

.tool-content {
  text-align: center;
  padding: 60rpx 0;
  color: #C0C4CC;
  font-size: 28rpx;
}

/* ===== 情绪调节策略 - 渐变选择效果 ===== */
.strategy-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.strategy-item {
  display: flex;
  align-items: flex-start;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  border-radius: 14rpx;
  padding: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.strategy-item.selected {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-color: #667eea;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
}

.strategy-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.strategy-info {
  flex: 1;
}

.strategy-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 6rpx;
}

.strategy-desc {
  font-size: 24rpx;
  color: #909399;
  line-height: 1.5;
}

/* ===== 自我反思 - 渐变输入框 ===== */
.reflection-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.reflection-q {
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.reflection-input {
  width: 100%;
  height: 120rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

/* ===== 压力评估 - 渐变结果框 ===== */
.stress-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.stress-q {
  font-size: 26rpx;
  color: #303133;
  display: block;
  margin-bottom: 8rpx;
}

.stress-result {
  margin-top: 24rpx;
  background: linear-gradient(135deg, rgba(67, 233, 123, 0.1), rgba(56, 249, 215, 0.1));
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(67, 233, 123, 0.2);
}

.result-level {
  font-size: 28rpx;
  color: #e8823a;
  display: block;
  margin: 8rpx 0;
  font-weight: 600;
}

.result-advice {
  font-size: 24rpx;
  color: #606266;
  line-height: 1.5;
}

/* ===== 性格测试 - 渐变选项 ===== */
.character-q {
  margin-bottom: 24rpx;
}

.q-text {
  font-size: 26rpx;
  color: #303133;
  display: block;
  margin-bottom: 12rpx;
}

radio-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

radio {
  font-size: 26rpx;
  transform: scale(0.9);
}

.character-result {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.result-emoji {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.result-desc {
  font-size: 24rpx;
  opacity: 0.9;
  line-height: 1.5;
}

/* ===== 通用提示 - 渐变背景 ===== */
.tool-tip {
  background: linear-gradient(135deg, rgba(255, 154, 68, 0.1), rgba(252, 96, 118, 0.1));
  border-radius: 14rpx;
  padding: 20rpx;
  margin: 16rpx 0;
  border: 1rpx solid rgba(255, 154, 68, 0.2);
}

.tool-tip text {
  font-size: 26rpx;
  color: #e8823a;
  line-height: 1.6;
}

.go-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #43e97b, #38f9d7);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(67, 233, 123, 0.3);
}

/* ===== 查看完整统计入口 ===== */
.go-diary-stats {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  cursor: pointer;
}
.go-diary-stats:active {
  opacity: 0.85;
  transform: scale(0.98);
}
.go-diary-stats-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}
.go-diary-stats-arrow {
  font-size: 36rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== 情绪能量图谱 ===== */
.energy-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.energy-stat-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}
.energy-stat-card.accent {
  background: linear-gradient(135deg, #43e97b, #38f9d7);
}
.energy-stat-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  display: block;
}
.energy-stat-top {
  font-size: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.energy-stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  display: block;
  margin-top: 4rpx;
}

/* 趋势图 */
.chart-section {
  margin-bottom: 28rpx;
}
.chart-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 16rpx;
}
.chart-scroll {
  width: 100%;
  height: 360rpx;
  white-space: nowrap;
}
.chart-inner {
  position: relative;
  height: 350rpx;
}
.chart-column {
  position: absolute;
  bottom: 0;
  width: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.chart-bar {
  width: 40rpx;
  min-height: 8rpx;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.chart-bar-label {
  font-size: 20rpx;
  color: #606266;
  margin-top: 6rpx;
  max-width: 60rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}
.chart-date-label {
  font-size: 18rpx;
  color: #C0C4CC;
  text-align: center;
}

/* 分布图 */
.dist-section {
  margin-top: 8rpx;
}
.dist-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.dist-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.dist-left {
  display: flex;
  align-items: center;
  width: 140rpx;
}
.dist-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  flex-shrink: 0;
}
.dist-name {
  font-size: 26rpx;
  color: #606266;
}
.dist-right {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.dist-bar-wrap {
  flex: 1;
  height: 14rpx;
  background: #f0f0f0;
  border-radius: 7rpx;
  overflow: hidden;
}
.dist-bar-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.5s ease;
}
.dist-count {
  font-size: 24rpx;
  color: #909399;
  width: 50rpx;
  text-align: right;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 60rpx 0;
}
.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}
.empty-title {
  font-size: 30rpx;
  color: #303133;
  display: block;
  margin-bottom: 8rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #909399;
}

/* ===== 价值观澄清 ===== */
.value-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 20rpx;
}
.value-chip {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
  gap: 6rpx;
  border: 2rpx solid #e4e7ed;
  transition: all 0.25s;
  position: relative;
  opacity: 0.55;
}
.value-chip.selected {
  opacity: 1;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-color: #667eea;
  box-shadow: 0 4rpx 20rpx rgba(102,126,234,0.4);
  transform: scale(1.05);
}
.value-chip:active { transform: scale(0.95); }
.value-chip.selected:active { transform: scale(1); }
.value-chip-emoji { font-size: 28rpx; opacity: 0.6; }
.value-chip.selected .value-chip-emoji { opacity: 1; }
.value-chip-name { font-size: 26rpx; font-weight: 500; color: #909399; }
.value-chip.selected .value-chip-name { color: #fff; font-weight: 600; }
.value-chip-check {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  font-size: 20rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1;
  flex-shrink: 0;
}
.value-counter {
  font-size: 24rpx; color: #909399;
  text-align: center; margin-bottom: 16rpx;
}

/* 排序列表 */
.value-rank-list {
  display: flex; flex-direction: column; gap: 12rpx; margin-bottom: 20rpx;
}
.value-rank-item {
  display: flex; align-items: center;
  background: linear-gradient(135deg, rgba(102,126,234,0.05), rgba(118,75,162,0.05));
  border-radius: 14rpx; padding: 16rpx 20rpx;
  border: 1rpx solid rgba(102,126,234,0.1);
}
.value-rank-num {
  width: 40rpx; font-size: 28rpx; font-weight: 700; color: #667eea;
}
.value-rank-name {
  flex: 1; font-size: 28rpx; color: #303133; font-weight: 500;
}
.value-rank-actions { display: flex; gap: 8rpx; }
.rank-btn {
  font-size: 24rpx; color: #909399;
  padding: 8rpx 12rpx; border-radius: 8rpx;
  background: rgba(0,0,0,0.03);
}
.rank-btn:active { background: rgba(102,126,234,0.1); color: #667eea; }
.reset-btn { background: transparent !important; color: #909399 !important; box-shadow: none !important; margin-top: 8rpx; }

/* 结果卡片 */
.value-result-card {
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 24rpx; padding: 32rpx 28rpx;
  color: #fff; margin-bottom: 20rpx;
}
.value-result-title {
  font-size: 32rpx; font-weight: 700;
  display: block; text-align: center; margin-bottom: 24rpx;
}
.value-podium {
  display: flex; flex-direction: column; align-items: center;
  gap: 12rpx; margin-bottom: 24rpx;
}
.podium-item { text-align: center; padding: 12rpx 24rpx; border-radius: 16rpx; background: rgba(255,255,255,0.15); }
.podium-item.gold { background: rgba(255,215,0,0.25); }
.podium-item.silver { background: rgba(192,192,192,0.25); }
.podium-item.bronze { background: rgba(205,127,50,0.25); }
.podium-row { display: flex; gap: 20rpx; }
.podium-num { font-size: 36rpx; display: block; }
.podium-name { font-size: 30rpx; font-weight: 700; display: block; margin-top: 4rpx; }
.value-result-summary {
  font-size: 26rpx; line-height: 1.6; display: block;
  margin-bottom: 20rpx; opacity: 0.9;
}
.value-insight-list { display: flex; flex-direction: column; gap: 10rpx; margin-bottom: 20rpx; }
.value-insight-item {
  background: rgba(255,255,255,0.1);
  border-radius: 12rpx; padding: 14rpx 18rpx;
}
.value-insight-text { font-size: 24rpx; line-height: 1.5; opacity: 0.95; }
.value-result-advice {
  font-size: 24rpx; line-height: 1.6; display: block;
  white-space: pre-wrap; opacity: 0.85;
}
