/* components/body-scan/body-scan.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0ff 0%, #fff 100%);
  padding-bottom: 40rpx;
}

/* ========== 头部 ========== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #a29bfe, #6c5ce7);
}

.header-left {
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  margin-right: 4rpx;
}

.back-text {
  font-size: 28rpx;
  color: #fff;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  width: 100rpx;
}

/* ========== 说明区域 ========== */
.intro-section {
  padding: 32rpx;
  background: rgba(162, 155, 254, 0.1);
  border-bottom: 1rpx solid rgba(162, 155, 254, 0.2);
}

.intro-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* ========== 进度 ========== */
.progress {
  padding: 24rpx 32rpx;
}

.progress-text {
  display: block;
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

/* ========== 开始卡片 ========== */
.start-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  text-align: center;
}

.start-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.start-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #a29bfe;
  margin-bottom: 16rpx;
}

.start-desc {
  font-size: 28rpx;
  color: #888;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.start-btn {
  background: linear-gradient(135deg, #a29bfe, #6c5ce7);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(108, 92, 231, 0.4);
}

/* ========== 指令卡片 ========== */
.instruction-card {
  background: linear-gradient(135deg, #a29bfe 0%, #6c5ce7 100%);
  border-radius: 24rpx;
  padding: 50rpx;
  text-align: center;
  color: #fff;
  margin: 32rpx;
}

.part {
  font-size: 28rpx;
  opacity: 0.8;
  margin-bottom: 20rpx;
}

.instruction {
  font-size: 34rpx;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.timer {
  font-size: 60rpx;
  font-weight: bold;
}

/* ========== 完成卡片 ========== */
.completed-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 32rpx;
  text-align: center;
  margin: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.completed-emoji {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.completed-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #a29bfe;
  display: block;
  margin-bottom: 16rpx;
}

.completed-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

/* ========== 小贴士 ========== */
.tip-section {
  width: 100%;
  background: linear-gradient(135deg, rgba(162, 155, 254, 0.1), rgba(108, 92, 231, 0.1));
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  text-align: left;
}

.tip-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #a29bfe;
  margin-bottom: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== 完成按钮 ========== */
.finished-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #26de81, #20bf6b);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(38, 222, 129, 0.4);
}

.action-btn.secondary {
  background: transparent;
  color: #a29bfe;
  border: 2rpx solid #a29bfe;
}
