/* components/emergency-contacts/emergency-contacts.wxss */

.contacts-container {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

/* ========== 标题栏 ========== */
.contacts-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1), rgba(254, 202, 87, 0.1));
  border-bottom: 1rpx solid rgba(255, 107, 107, 0.1);
}

.contacts-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.contacts-count {
  font-size: 24rpx;
  color: #999;
}

/* ========== 联系人列表 ========== */
.contacts-list {
  padding: 0 24rpx;
}

.contact-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-info {
  margin-bottom: 16rpx;
}

.contact-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.contact-relation {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: #667eea;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  margin-right: 12rpx;
}

.contact-phone {
  font-size: 26rpx;
  color: #666;
}

/* ========== 操作按钮 ========== */
.contact-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.action-btn.call {
  background: linear-gradient(135deg, #26de81, #20bf6b);
  color: #fff;
}

.action-btn.edit {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
}

.action-btn.delete {
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

/* ========== 添加按钮 ========== */
.add-contact-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border-top: 1rpx dashed #e0e0e0;
}

.add-icon {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.add-text {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: 500;
}
