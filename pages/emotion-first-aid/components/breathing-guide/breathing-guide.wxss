/* components/breathing-guide/breathing-guide.wxss */

.breathing-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f4ff 0%, #fff 100%);
  padding-bottom: 40rpx;
}

/* ========== 头部 ========== */
.breathing-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

.header-left {
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  margin-right: 4rpx;
}

.back-text {
  font-size: 28rpx;
  color: #fff;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  width: 100rpx;
}

/* ========== 内容区域 ========== */
.breathing-content {
  padding: 40rpx 32rpx;
}

.breathing-content.active {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ========== 准备状态 ========== */
.ready-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-top: 60rpx;
}

.ready-emoji {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.ready-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.ready-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: left;
  background: #f8f9ff;
  padding: 32rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
}

.start-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

/* ========== 循环进度 ========== */
.cycle-progress {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.cycle-text {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.cycle-dots {
  display: flex;
  gap: 12rpx;
}

.cycle-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e0e0e0;
  transition: all 0.3s ease;
}

.cycle-dot.completed {
  background: #667eea;
}

/* ========== 呼吸动画圆 ========== */
.breathing-circle-wrapper {
  width: 320rpx;
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.breathing-circle {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.4);
}

.breathing-circle.inhale {
  width: 300rpx;
  height: 300rpx;
  animation: breatheIn 4s ease-in-out forwards;
  background: linear-gradient(135deg, #4facfe, #00f2fe);
}

.breathing-circle.hold {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.breathing-circle.exhale {
  width: 200rpx;
  height: 200rpx;
  animation: breatheOut 8s ease-in-out forwards;
  background: linear-gradient(135deg, #667eea, #764ba2);
}

@keyframes breatheIn {
  0% { transform: scale(1); }
  100% { transform: scale(1.5); }
}

@keyframes breatheOut {
  0% { transform: scale(1.5); }
  100% { transform: scale(1); }
}

.circle-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.phase-emoji {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.phase-label {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.countdown-num {
  font-size: 56rpx;
  color: #fff;
  font-weight: 700;
}

/* ========== 指导语 ========== */
.instruction-section {
  background: rgba(102, 126, 234, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  margin-bottom: 40rpx;
}

.instruction-text {
  font-size: 30rpx;
  color: #667eea;
  font-weight: 500;
  text-align: center;
}

/* ========== 阶段指示 ========== */
.phase-indicator {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.phase-item {
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  background: #f0f0f0;
  opacity: 0.5;
  transition: all 0.3s ease;
}

.phase-item.active {
  background: rgba(102, 126, 234, 0.15);
  opacity: 1;
}

.phase-item text {
  font-size: 22rpx;
  color: #888;
}

.phase-item.active text {
  color: #667eea;
  font-weight: 500;
}

/* ========== 停止按钮 ========== */
.stop-btn {
  background: transparent;
  color: #999;
  font-size: 26rpx;
  padding: 16rpx 40rpx;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
}

/* ========== 完成状态 ========== */
.finished-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-top: 80rpx;
}

.finished-emoji {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.finished-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.finished-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 48rpx;
}

.finished-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  padding: 20rpx 48rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #26de81, #20bf6b);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(38, 222, 129, 0.4);
}

.action-btn.secondary {
  background: transparent;
  color: #667eea;
  border: 2rpx solid #667eea;
}
