/* components/sensory-calm/sensory-calm.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0fff8 0%, #fff 100%);
  padding-bottom: 40rpx;
}

/* ========== 头部 ========== */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #55efc4, #00b894);
}

.header-left {
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  margin-right: 4rpx;
}

.back-text {
  font-size: 28rpx;
  color: #fff;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  width: 100rpx;
}

/* ========== 说明区域 ========== */
.intro-section {
  padding: 32rpx;
  background: rgba(85, 239, 196, 0.1);
  border-bottom: 1rpx solid rgba(85, 239, 196, 0.2);
}

.intro-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* ========== 方法内容 ========== */
.method-content {
  padding: 32rpx;
}

.method-list {
  margin-bottom: 32rpx;
}

.method-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.method-card:active {
  transform: scale(0.98);
}

.method-card.selected {
  border-color: #00b894;
  background: linear-gradient(135deg, rgba(85, 239, 196, 0.08) 0%, rgba(0, 184, 148, 0.08) 100%);
  box-shadow: 0 4rpx 20rpx rgba(0, 184, 148, 0.15);
}

.method-emoji {
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.method-info {
  flex: 1;
}

.method-type {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.method-instruction {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
  line-height: 1.4;
}

.method-effect {
  display: block;
  font-size: 22rpx;
  color: #00b894;
}

.method-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #00b894;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ========== 完成按钮 ========== */
.finish-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: #e0e0e0;
  color: #999;
  border: none;
  transition: all 0.3s ease;
}

.finish-btn.ready {
  background: linear-gradient(135deg, #55efc4, #00b894);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 184, 148, 0.4);
}

/* ========== 完成状态 ========== */
.completed-content {
  padding: 32rpx;
}

.completed-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.completed-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.completed-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.completed-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 32rpx;
}

/* ========== 结果区域 ========== */
.result-section {
  width: 100%;
  margin-bottom: 24rpx;
}

.result-item {
  background: rgba(85, 239, 196, 0.1);
  border: 1rpx solid rgba(85, 239, 196, 0.3);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: left;
}

.result-label {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.result-value {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

/* ========== 小贴士 ========== */
.tip-section {
  width: 100%;
  background: linear-gradient(135deg, rgba(85, 239, 196, 0.1), rgba(0, 184, 148, 0.1));
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  text-align: left;
}

.tip-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #00b894;
  margin-bottom: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== 完成按钮 ========== */
.finished-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #26de81, #20bf6b);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(38, 222, 129, 0.4);
}

.action-btn.secondary {
  background: transparent;
  color: #00b894;
  border: 2rpx solid #00b894;
}
