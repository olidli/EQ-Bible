/* components/grounding-technique/grounding-technique.wxss */

.grounding-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5ff 0%, #fff 100%);
  padding-bottom: 40rpx;
}

/* ========== 头部 ========== */
.grounding-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.header-left {
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  margin-right: 4rpx;
}

.back-text {
  font-size: 28rpx;
  color: #fff;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  width: 100rpx;
}

/* ========== 说明区域 ========== */
.intro-section {
  padding: 32rpx;
  background: rgba(240, 147, 251, 0.1);
  border-bottom: 1rpx solid rgba(240, 147, 251, 0.2);
}

.intro-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* ========== 进度 ========== */
.step-progress {
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f093fb, #f5576c);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

/* ========== 步骤指示器 ========== */
.step-indicators {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  color: #999;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.step-dot.active {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(240, 147, 251, 0.4);
}

/* ========== 当前步骤卡片 ========== */
.step-content {
  padding: 0 32rpx;
}

.current-step-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.step-emoji {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.step-number {
  font-size: 80rpx;
  font-weight: 700;
  color: #f5576c;
  line-height: 1;
  margin-bottom: 8rpx;
}

.step-sense {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.step-prompt {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.step-input {
  width: 100%;
  min-height: 120rpx;
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.step-input:focus {
  border-color: #f093fb;
  background: #fff;
}

.input-hint {
  margin-top: 16rpx;
}

.input-hint text {
  font-size: 24rpx;
  color: #ccc;
}

/* ========== 下一步按钮 ========== */
.next-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: #e0e0e0;
  color: #999;
  border: none;
  transition: all 0.3s ease;
}

.next-btn.ready {
  background: linear-gradient(135deg, #f093fb, #f5576c);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(240, 147, 251, 0.4);
}

/* ========== 完成状态 ========== */
.finished-content {
  padding: 32rpx;
}

.finished-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.finished-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.finished-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.finished-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 32rpx;
}

/* ========== 回顾区域 ========== */
.review-section {
  width: 100%;
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.review-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 20rpx;
  text-align: left;
}

.review-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.review-item:last-child {
  border-bottom: none;
}

.review-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.review-value {
  font-size: 26rpx;
  color: #333;
  text-align: left;
}

/* ========== 完成按钮 ========== */
.finished-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #26de81, #20bf6b);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(38, 222, 129, 0.4);
}

.action-btn.secondary {
  background: transparent;
  color: #f5576c;
  border: 2rpx solid #f5576c;
}
