/* components/cognitive-reappraisal/cognitive-reappraisal.wxss */

.cognitive-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0fff8 0%, #fff 100%);
  padding-bottom: 40rpx;
}

/* ========== 头部 ========== */
.cognitive-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #4ecdc4, #44bd9e);
}

.header-left {
  display: flex;
  align-items: center;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  margin-right: 4rpx;
}

.back-text {
  font-size: 28rpx;
  color: #fff;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  width: 100rpx;
}

/* ========== 说明区域 ========== */
.intro-section {
  padding: 32rpx;
  background: rgba(78, 205, 196, 0.1);
  border-bottom: 1rpx solid rgba(78, 205, 196, 0.2);
}

.intro-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
}

/* ========== 进度 ========== */
.step-progress {
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ecdc4, #44bd9e);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

/* ========== 问题内容 ========== */
.question-content {
  padding: 0 32rpx;
}

.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.question-emoji {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.question-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.answer-input {
  width: 100%;
  min-height: 160rpx;
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  text-align: left;
}

.answer-input:focus {
  border-color: #4ecdc4;
  background: #fff;
}

/* ========== 回答预览 ========== */
.answers-preview {
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.preview-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 16rpx;
  text-align: left;
}

.preview-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.preview-item:last-child {
  border-bottom: none;
}

.preview-q {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
  text-align: left;
}

.preview-a {
  display: block;
  font-size: 26rpx;
  color: #333;
  text-align: left;
}

/* ========== 下一步按钮 ========== */
.next-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  background: #e0e0e0;
  color: #999;
  border: none;
  transition: all 0.3s ease;
}

.next-btn.ready {
  background: linear-gradient(135deg, #4ecdc4, #44bd9e);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(78, 205, 196, 0.4);
}

/* ========== 完成状态 ========== */
.finished-content {
  padding: 32rpx;
}

.finished-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.finished-emoji {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.finished-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.finished-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 32rpx;
}

/* ========== 结果区域 ========== */
.result-section {
  width: 100%;
  margin-bottom: 24rpx;
}

.result-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 16rpx;
  text-align: left;
}

.result-item {
  background: #f8f9ff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  text-align: left;
}

.result-item.balanced {
  background: rgba(78, 205, 196, 0.1);
  border: 1rpx solid rgba(78, 205, 196, 0.3);
}

.result-label {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.result-value {
  display: block;
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

/* ========== 小贴士 ========== */
.tip-section {
  width: 100%;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  text-align: left;
}

.tip-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #667eea;
  margin-bottom: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== 完成按钮 ========== */
.finished-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: linear-gradient(135deg, #26de81, #20bf6b);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(38, 222, 129, 0.4);
}

.action-btn.secondary {
  background: transparent;
  color: #4ecdc4;
  border: 2rpx solid #4ecdc4;
}
