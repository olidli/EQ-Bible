/* pages/emotion-first-aid/edit-contact/edit-contact.wxss */

.container {
  min-height: 100vh;
  background: #f8f9ff;
  padding: 32rpx;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f8f9ff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #667eea;
  background: #fff;
}

.save-btn {
  background: linear-gradient(135deg, #ff6b6b, #feca57);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 28rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  margin-bottom: 24rpx;
}

.save-btn:active {
  transform: scale(0.98);
}

.delete-btn {
  background: transparent;
  color: #ff6b6b;
  font-size: 28rpx;
  padding: 24rpx;
  border: 2rpx solid #ff6b6b;
  border-radius: 50rpx;
}

.delete-btn:active {
  background: rgba(255, 107, 107, 0.1);
}
