/* pages/emotion-first-aid/emotion-first-aid.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff5f5 0%, #fff 100%);
  padding-bottom: 40rpx;
}

/* ========== 步骤指示器 ========== */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 100rpx;
  background: linear-gradient(135deg, #ff6b6b, #feca57);
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.step-dot.active {
  background: #fff;
  color: #ff6b6b;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.step-dot.completed {
  background: #26de81;
  color: #fff;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.4);
  margin: 0 8rpx;
  transition: all 0.3s ease;
}

.step-line.active {
  background: #fff;
}

/* ========== 步骤内容 ========== */
.step-content {
  padding: 32rpx 32rpx;
}

.step-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.step-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.step-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* ========== 情绪选择网格 ========== */
.emotion-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.emotion-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.emotion-btn:active {
  transform: scale(0.95);
}

.emotion-btn.selected {
  border-color: var(--emotion-color);
  background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(255,255,255,0.6));
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.emotion-emoji {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.emotion-label {
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
}

/* ========== 强度选择 ========== */
.intensity-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.intensity-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.intensity-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.intensity-value {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
}

.intensity-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
}

/* ========== 确认按钮 ========== */
.confirm-btn {
  background: linear-gradient(135deg, #ff6b6b, #feca57);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
}

.confirm-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

/* ========== 引导语面板 ========== */
.guidance-panel {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  color: #fff;
}

.guidance-title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.guidance-desc {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.guidance-tip {
  font-size: 24rpx;
  opacity: 0.8;
  font-style: italic;
}

/* ========== 工具列表 ========== */
.tool-list {
  margin-bottom: 32rpx;
}

.tool-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  position: relative;
}

.tool-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.tool-card.recommended {
  border: 2rpx solid #667eea;
  background: linear-gradient(135deg, rgba(102,126,234,0.08) 0%, rgba(118,75,162,0.08) 100%);
}

.recommended-badge {
  position: absolute;
  top: 20rpx;
  right: 80rpx;
  background: #667eea;
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.tool-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.tool-info {
  flex: 1;
}

.tool-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.tool-desc {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.tool-duration {
  display: block;
  font-size: 22rpx;
  color: #aaa;
}

.tool-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 16rpx;
}

/* ========== 应急联系人入口 ========== */
.contacts-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1), rgba(254, 202, 87, 0.1));
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx dashed rgba(255, 107, 107, 0.3);
}

.contacts-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.contacts-text {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: 500;
}

.contacts-arrow {
  font-size: 24rpx;
  color: #ff6b6b;
  margin-left: 12rpx;
}

.contacts-panel {
  margin-bottom: 20rpx;
}

/* ========== 返回按钮 ========== */
.back-btn {
  text-align: center;
  padding: 20rpx;
}

.back-btn text {
  font-size: 26rpx;
  color: #999;
}

/* ========== 工具面板 ========== */
.tool-panel {
  padding: 0;
}
