<!-- pages/path/path.wxml -->
<view class="container">
  <view class="header">
    <text class="title">🗺 学习路径</text>
    <text class="desc">根据目标生成个性化学习计划</text>
  </view>
  <view class="empty" wx:if="{{savedPaths.length === 0}}">
    <text class="empty-text">还没有保存的学习路径</text>
    <button class="go-btn" bindtap="goTools">生成学习路径</button>
  </view>
  <view class="path-list" wx:else>
    <view class="path-item" wx:for="{{savedPaths}}" wx:key="index">
      <text class="path-goal">🎯 {{item.goal}}</text>
      <text class="path-duration">⏱ {{item.duration}}</text>
    </view>
  </view>
  <button class="go-btn" wx:if="{{savedPaths.length > 0}}" bindtap="goTools">生成新路径</button>
</view>