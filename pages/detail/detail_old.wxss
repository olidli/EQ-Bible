/* pages/detail/detail.wxss */

.container {
  padding: 0 0 40rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* ===== 标题区 ===== */
.header {
  background: #fff;
  padding: 28rpx 24rpx;
  margin-bottom: 2rpx;
}

.type-badge {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  margin-bottom: 12rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #303133;
  display: block;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 22rpx;
  color: #667eea;
  background: #F0F2FF;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* ===== 操作按钮 ===== */
.actions {
  display: flex;
  background: #fff;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  background: #F5F7FA;
  border-radius: 12rpx;
}

.action-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.action-text {
  font-size: 22rpx;
  color: #606266;
}

/* ===== 内容区 ===== */
.content-body {
  padding: 0 24rpx;
}

.desc-section,
.tool-section,
.related-section,
.case-section,
.source-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 16rpx;
}

.desc-text {
  font-size: 28rpx;
  color: #606266;
  line-height: 1.8;
}

/* ===== 工具区 ===== */
.tool-guide {
  background: #F0F9EB;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.guide-text {
  font-size: 26rpx;
  color: #303133;
  line-height: 1.6;
}

.start-btn {
  width: 100%;
  height: 84rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 84rpx;
}

.start-btn::after {
  border: none;
}

/* ===== 相关内容 ===== */
.related-list {
  display: flex;
  flex-direction: column;
}

.related-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F6FC;
}

.related-item:last-child {
  border-bottom: none;
}

.related-title {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
  line-height: 1.4;
}

.related-arrow {
  font-size: 32rpx;
  color: #C0C4CC;
  margin-left: 16rpx;
}

/* ===== 案例列表 ===== */
.case-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.case-text {
  font-size: 28rpx;
  color: #606266;
  line-height: 1.7;
  background: #F5F7FA;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
}

/* ===== 来源信息 ===== */
.source-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.source-item {
  font-size: 26rpx;
  color: #909399;
}

/* ===== 加载状态 ===== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #C0C4CC;
  font-size: 28rpx;
}
