<view class="container">
  <!-- 福格·Motivation：挑战式标题，比"测情商"更有驱动力 -->
  <view class="header">
    <view class="title-emoji">🧠</view>
    <view class="title">你能活过几关？</view>
    <view class="subtitle">90%的人死在第3题</view>
  </view>

  <!-- 福格·Prompt+Motivation：限时今日挑战，制造紧迫感 -->
  <view class="daily-challenge" bindtap="onDailyChallenge">
    <view class="daily-top-row">
      <view class="daily-badge">🎯 今日挑战</view>
      <view class="daily-countdown">仅限今日</view>
    </view>
    <view class="daily-title">{{dailyScene.title || '快来挑战'}}</view>
    <view class="daily-info">
      <text class="daily-streak">🔥 连续{{streak}}天</text>
      <text class="daily-hint">已{{dailyPlayedCount}}人挑战</text>
    </view>
  </view>

  <!-- 场景分类 -->
  <view class="section-title">选择场景</view>

  <!-- 校园场景 -->
  <view class="category-card campus" bindtap="onStartGame" data-category="campus">
    <view class="category-icon">🎓</view>
    <view class="category-info">
      <view class="category-name">校园生存篇</view>
      <view class="category-desc">室友、社团、课堂…你最怕哪个？</view>
    </view>
    <view class="category-count">56题</view>
  </view>

  <!-- 家庭聚会 -->
  <view class="category-card family" bindtap="onStartGame" data-category="family">
    <view class="category-icon">🏠</view>
    <view class="category-info">
      <view class="category-name">家庭聚会篇</view>
      <view class="category-desc">爸妈吵架、催婚、翻手机…夹在中间难做人</view>
    </view>
    <view class="category-count">12题</view>
  </view>

  <!-- 约会恋爱 -->
  <view class="category-card dating" bindtap="onStartGame" data-category="dating">
    <view class="category-icon">💕</view>
    <view class="category-info">
      <view class="category-name">约会恋爱篇</view>
      <view class="category-desc">AA还是请客？冷战谁先低头？心动也是社死</view>
    </view>
    <view class="category-count">12题</view>
  </view>

  <!-- 微信群聊 -->
  <view class="category-card wechat" bindtap="onStartGame" data-category="wechat">
    <view class="category-icon">📱</view>
    <view class="category-info">
      <view class="category-name">微信群聊篇</view>
      <view class="category-desc">发错消息、被@、老板在群里…每条都是地雷</view>
    </view>
    <view class="category-count">11题</view>
  </view>

  <!-- 亲戚过年 -->
  <view class="category-card relative" bindtap="onStartGame" data-category="relative">
    <view class="category-icon">🧧</view>
    <view class="category-info">
      <view class="category-name">亲戚过年篇</view>
      <view class="category-desc">催婚、比工资、敬酒…过年回家的社死战场</view>
    </view>
    <view class="category-count">9题</view>
  </view>

  <!-- 我的战绩 -->
  <view class="section-title">我的战绩</view>
  <view class="stats-row">
    <view class="stat-item">
      <view class="stat-value">{{playedCount}}</view>
      <view class="stat-label">已挑战</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{avgScore}}</view>
      <view class="stat-label">平均分</view>
    </view>
    <view class="stat-item">
      <view class="stat-value">{{bestLevel}}</view>
      <view class="stat-label">最佳段位</view>
    </view>
  </view>

  <!-- 排行榜入口 -->
  <view class="rank-entry" bindtap="goRank">
    <text>🏆 好友排行榜</text>
    <text class="rank-arrow">›</text>
  </view>
</view>
