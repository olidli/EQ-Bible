.container {
  padding: 30rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  min-height: 100vh;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: #2a2a4a;
  border-radius: 4rpx;
  margin-bottom: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ecdc4, #44a8e8);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-text {
  color: #8892b0;
  font-size: 22rpx;
  text-align: right;
  margin-bottom: 30rpx;
}

/* 场景卡片 */
.scene-card {
  background: #1f2940;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}

.scene-tag {
  display: inline-block;
  background: rgba(78, 205, 196, 0.15);
  color: #4ecdc4;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.scene-title {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.scene-desc {
  color: #a8b2d1;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 选项 */
.options-area {
  margin-top: 10rpx;
}

.option-item {
  display: flex;
  align-items: flex-start;
  background: #1f2940;
  border: 2rpx solid #2a3a5a;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s;
}

.option-item.selected {
  border-color: #4ecdc4;
  background: rgba(78, 205, 196, 0.08);
}

.option-item:active {
  transform: scale(0.98);
}

.option-letter {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #2a3a5a;
  color: #4ecdc4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-text {
  color: #e6f1ff;
  font-size: 28rpx;
  line-height: 1.5;
  padding-top: 6rpx;
}

/* 反馈区 */
.feedback-card {
  background: #1f2940;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid;
}

.feedback-card.high {
  border-color: #4ecdc4;
}

.feedback-card.mid {
  border-color: #ffe66d;
}

.feedback-card.low {
  border-color: #e94560;
}

.feedback-level-badge {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 14rpx;
}

.feedback-card.high .feedback-level-badge {
  color: #4ecdc4;
}

.feedback-card.mid .feedback-level-badge {
  color: #ffe66d;
}

.feedback-card.low .feedback-level-badge {
  color: #e94560;
}

.feedback-text {
  color: #a8b2d1;
  font-size: 26rpx;
  line-height: 1.7;
}

/* 所有选项对比 */
.all-options {
  margin-bottom: 30rpx;
}

.option-review {
  background: #1f2940;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 14rpx;
  border-left: 4rpx solid #2a3a5a;
}

.option-review.best {
  border-color: #4ecdc4;
  background: rgba(78, 205, 196, 0.06);
}

.option-review.worst {
  border-color: #e94560;
  opacity: 0.7;
}

.review-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.review-letter {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #2a3a5a;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.review-level-tag {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.review-level-tag.high {
  background: rgba(78, 205, 196, 0.15);
  color: #4ecdc4;
}

.review-level-tag.mid {
  background: rgba(255, 230, 109, 0.15);
  color: #ffe66d;
}

.review-level-tag.low {
  background: rgba(233, 69, 96, 0.15);
  color: #e94560;
}

.review-your-pick {
  font-size: 20rpx;
  color: #8892b0;
  margin-left: auto;
}

.review-text {
  color: #e6f1ff;
  font-size: 26rpx;
  line-height: 1.5;
}

/* 下一题按钮 */
.next-btn {
  background: linear-gradient(135deg, #4ecdc4, #44a8e8);
  color: #1a1a2e;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 28rpx;
  border-radius: 50rpx;
  margin-top: 10rpx;
}

.next-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
