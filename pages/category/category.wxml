<!-- pages/category/category.wxml -->
<view class="container">
  <!-- 二级导航 - 横向滚动标签 -->
  <scroll-view class="sub-nav" scroll-x enable-flex>
    <view class="sub-nav-item {{currentTab === item.id ? 'active' : ''}}"
      wx:for="{{categories}}" wx:key="id" bindtap="switchTab" data-id="{{item.id}}">
      <text>{{item.emoji}} {{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 紧凑横幅 - 模块信息 -->
  <view class="module-banner" wx:if="{{currentModule}}">
    <view class="banner-left">
      <view class="banner-emoji">{{currentModule.emoji}}</view>
      <view class="banner-info">
        <text class="banner-name">{{currentModule.name}}</text>
        <text class="banner-count">{{itemCount}} 篇内容</text>
      </view>
    </view>
    <text class="banner-desc">{{currentModule.desc}}</text>
  </view>

  <!-- 内容列表 - 主体区域 -->
  <view class="content-area">
    <view class="content-header">
      <text class="content-title">全部内容</text>
      <text class="content-total">共 {{itemCount}} 条</text>
    </view>

    <view class="item-list" wx:if="{{items.length > 0}}">
      <view class="item-card" wx:for="{{items}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
        <view class="item-top">
          <view class="item-type-badge" style="background: {{item.typeColor}};">{{item.typeLabel}}</view>
          <view class="item-learned" wx:if="{{item.hasLearned}}">✓ 已学</view>
        </view>
        <text class="item-title">{{item.title}}</text>
        <text class="item-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <view class="item-meta">
          <view class="item-tags" wx:if="{{item.tags.length > 0}}">
            <text class="item-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 3}}">{{tag}}</text>
          </view>
          <text class="item-reading" wx:if="{{item.readTime}}">{{item.readTime}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:else>
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无内容</text>
      <text class="empty-hint">换个模块看看？</text>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
      <text class="load-more-text">加载更多</text>
    </view>
    <view class="no-more" wx:elif="{{items.length > 0 && !hasMore}}">
      <text class="no-more-text">已加载全部 {{itemCount}} 条内容</text>
    </view>
  </view>

  <!-- 案例库 -->
  <view class="case-section" wx:if="{{cases.length > 0}}">
    <view class="content-header">
      <text class="content-title">案例库</text>
      <text class="content-total">{{cases.length}} 个案例</text>
    </view>
    <view class="case-list">
      <view class="case-item" wx:for="{{cases}}" wx:key="*this" bindtap="goCase" data-id="{{item.id}}">
        <text class="case-title">{{item.title}}</text>
        <text class="case-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 工具条 - 横向滚动 -->
  <view class="tools-strip" wx:if="{{moduleTools.length > 0}}">
    <view class="content-header">
      <text class="content-title">实用工具</text>
    </view>
    <scroll-view class="tools-scroll" scroll-x enable-flex>
      <view class="tool-capsule" wx:for="{{moduleTools}}" wx:key="*this"
        bindtap="openTool" data-tool="{{item.id}}">
        <text class="tool-capsule-emoji">{{item.emoji}}</text>
        <text class="tool-capsule-name">{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 底部安全区 -->
  <view class="bottom-safe"></view>
</view>
