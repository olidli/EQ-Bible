<!-- pages/category/category.wxml -->
<view class="container">
  <!-- 二级导航 -->
  <scroll-view class="sub-nav" scroll-x enable-flex>
    <view class="sub-nav-item {{currentTab === item.id ? 'active' : ''}}" 
      wx:for="{{categories}}" wx:key="id" bindtap="switchTab" data-id="{{item.id}}">
      <text>{{item.emoji}} {{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 内容列表 -->
  <view class="content-list">
    <!-- 模块说明 -->
    <view class="module-intro" wx:if="{{currentModule}}">
      <text class="module-title">{{currentModule.name}}</text>
      <text class="module-desc">{{currentModule.desc}}</text>
      <view class="module-tools">
        <text class="module-tool-tag" wx:for="{{currentModule.tools}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 工具列表 -->
    <view class="section" wx:if="{{moduleTools.length > 0}}">
      <view class="section-title">🛠 实用工具</view>
      <view class="tool-cards">
        <view class="tool-card" wx:for="{{moduleTools}}" wx:key="*this" 
          bindtap="openTool" data-tool="{{item.id}}">
          <text class="tool-card-emoji">{{item.emoji}}</text>
          <text class="tool-card-name">{{item.name}}</text>
          <text class="tool-card-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <!-- 内容列表 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">📚 相关内容</text>
        <text class="section-count">共 {{items.length}} 条</text>
      </view>
      <view class="item-list" wx:if="{{items.length > 0}}">
        <view class="item-card" wx:for="{{items}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
          <view class="item-type-badge" style="background: {{item.typeColor}};">{{item.typeLabel}}</view>
          <text class="item-title">{{item.title}}</text>
          <view class="item-tags">
            <text class="item-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 4}}">{{tag}}</text>
          </view>
        </view>
      </view>
      <view class="empty" wx:else>
        <text>暂无相关内容</text>
      </view>
    </view>

    <!-- 案例列表 -->
    <view class="section" wx:if="{{cases.length > 0}}">
      <view class="section-title">📖 案例库</view>
      <view class="case-list">
        <view class="case-item" wx:for="{{cases}}" wx:key="*this" bindtap="goCase" data-id="{{item.id}}">
          <text class="case-title">{{item.title}}</text>
          <text class="case-arrow">›</text>
        </view>
      </view>
    </view>
  </view>
</view>
