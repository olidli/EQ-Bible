<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">📖 知识库</text>
    <text class="page-subtitle">六大模块 · 共 {{totalCount}} 篇内容</text>
  </view>

  <!-- 六个模块平铺 -->
  <view class="module-list">
    <view class="module-card" wx:for="{{modules}}" wx:for-index="modIndex" wx:key="id" wx:for-item="mod" style="border-left: 8rpx solid {{mod.color}};">

      <!-- 模块头部 -->
      <view class="mod-header" style="background: {{mod.bg}};">
        <view class="mod-avatar" style="background: {{mod.color}};">
          <text class="mod-emoji">{{mod.emoji}}</text>
        </view>
        <view class="mod-info">
          <text class="mod-name">{{mod.id}}</text>
          <text class="mod-count">{{mod.totalCount}} 篇</text>
        </view>
      </view>

      <!-- 子目录列表 -->
      <view class="child-list">
        <view wx:for="{{mod.children}}" wx:for-index="ci" wx:key="name" wx:for-item="child">
          <view class="child-item"
            bindtap="toggleChild" data-mi="{{modIndex}}" data-ci="{{ci}}">
            <view class="child-left">
              <view class="child-dot" style="background: {{child.expanded ? mod.color : '#e0e0e0'}};"></view>
              <text class="child-name" style="color: {{child.expanded ? mod.color : '#303133'}};">{{child.name}}</text>
              <text class="child-count">{{child.count}}篇</text>
            </view>
            <text class="child-arrow {{child.expanded ? 'arrow-up' : ''}}" style="color: {{child.expanded ? mod.color : '#c0c4cc'}};">›</text>
          </view>

          <!-- 展开内容区（现在在 wx:for 作用域内） -->
          <view class="child-items" wx:if="{{child.expandedData}}">
            <view class="item-card" wx:for="{{child.expandedData.items}}" wx:key="_id" wx:for-item="item"
              bindtap="goDetail" data-id="{{item._id}}">
          <view class="item-top">
              <text class="item-learned" wx:if="{{item.hasLearned}}">✓ 已学</text>
            </view>
              <text class="item-title">{{item.title}}</text>
              <text class="item-desc" wx:if="{{item.description}}">{{item.description}}</text>
              <view class="item-meta" wx:if="{{item.tags.length > 0 || item.readTime}}">
                <view class="item-tags">
                  <text class="item-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
                </view>
                <text class="item-reading" wx:if="{{item.readTime}}">{{item.readTime}}</text>
              </view>
            </view>

            <view class="load-more" wx:if="{{child.expandedData.hasMore}}" bindtap="loadMore" data-mi="{{modIndex}}" data-ci="{{ci}}">
              <text class="load-more-text" style="background: {{mod.color}}22; color: {{mod.color}};">加载更多</text>
            </view>
            <view class="no-more" wx:elif="{{child.expandedData.showNoMore}}">
              <text class="no-more-text">— 已加载全部 —</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-safe"></view>
</view>
