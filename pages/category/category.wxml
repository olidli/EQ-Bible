<view class="container">
  <!-- 顶部一级标签（横向滑动） -->
  <scroll-view class="sub-nav" scroll-x enable-flex show-scrollbar="{{false}}">
    <view class="sub-nav-item {{currentTreeTab === item.id ? 'active' : ''}}"
      wx:for="{{treeTabs}}" wx:key="id"
      bindtap="toggleTopTab" data-id="{{item.id}}">
      <text>{{item.emoji}} {{item.id}}</text>
      <text class="nav-count">{{item.count}}</text>
    </view>
  </scroll-view>

  <!-- 展开的子目录（折叠区域） -->
  <view class="tree-section" wx:if="{{treeTabs.find(t => t.id === currentTreeTab)?.expanded}}">
    <view class="sub-list">
      <view class="sub-item {{s.isActive ? 'active' : ''}}"
        wx:for="{{subCategories}}" wx:key="name"
        bindtap="selectSub" data-path="{{s.path}}">
        <view class="sub-item-left">
          <text class="sub-name">{{s.name}}</text>
          <text class="sub-count">{{s.count}}篇</text>
        </view>
        <text class="sub-arrow">{{s.isActive ? '▼' : '›'}}</text>
      </view>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content-area" wx:if="{{currentSub}}">
    <view class="content-header">
      <text class="content-title">📄 全部内容</text>
      <text class="content-count">{{itemCount}}篇</text>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{items.length === 0}}">
      <text>暂无内容，先去其他分类看看吧</text>
    </view>

    <!-- 内容卡片列表 -->
    <view class="item-list" wx:if="{{items.length > 0}}">
      <view class="item-card" wx:for="{{items}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
        <view class="item-top">
          <text class="item-type-badge" style="background:{{item.typeColor}}">{{item.typeLabel}}</text>
          <text class="item-learned" wx:if="{{item.hasLearned}}">✓ 已学</text>
        </view>
        <text class="item-title">{{item.title}}</text>
        <text class="item-desc" wx:if="{{item.description}}">{{item.description}}</text>
        <view class="item-meta">
          <view class="item-tags" wx:if="{{item.tags.length > 0}}">
            <text class="item-tag" wx:for="{{item.tags}}" wx:key="*this" wx:if="{{index < 3}}">{{item}}</text>
          </view>
          <text class="item-reading" wx:if="{{item.readTime}}">{{item.readTime}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">加载更多</view>
    <view class="no-more" wx:elif="{{items.length > 0 && !hasMore}}">已加载全部</view>
  </view>

  <!-- 推荐工具 -->
  <view class="tools-strip">
    <view class="content-header">
      <text class="content-title">🔧 实用工具</text>
    </view>
    <scroll-view class="tools-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
      <view class="tool-capsule" bindtap="openTool" data-tool="emotion_diary">
        <text class="tool-capsule-emoji">📝</text>
        <text class="tool-capsule-name">情绪日记</text>
      </view>
      <view class="tool-capsule" bindtap="openTool" data-tool="emotion_recognition">
        <text class="tool-capsule-emoji">🎭</text>
        <text class="tool-capsule-name">情绪识别</text>
      </view>
      <view class="tool-capsule" bindtap="openTool" data-tool="value_clarify">
        <text class="tool-capsule-emoji">💎</text>
        <text class="tool-capsule-name">价值观澄清</text>
      </view>
      <view class="tool-capsule" bindtap="openTool" data-tool="ability_assess">
        <text class="tool-capsule-emoji">📊</text>
        <text class="tool-capsule-name">能力评估</text>
      </view>
    </scroll-view>
  </view>

  <view class="bottom-safe"></view>
</view>
