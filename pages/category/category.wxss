/* pages/category/category.wxss - 分类页 v2：内容优先、结构清晰 */

.container {
  padding: 0;
  background: #f8f9ff;
  min-height: 100vh;
}

/* ===== 二级导航 - 固定顶部 ===== */
.sub-nav {
  white-space: nowrap;
  background: #fff;
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.06);
  position: sticky;
  top: 0;
  z-index: 100;
}

.sub-nav-item {
  display: inline-block;
  font-size: 26rpx;
  color: #606266;
  padding: 10rpx 22rpx;
  border-radius: 30rpx;
  margin-right: 10rpx;
  background: rgba(102, 126, 234, 0.06);
  transition: all 0.2s;
}

.sub-nav-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
}

/* ===== 紧凑横幅 ===== */
.module-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 24rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(102, 126, 234, 0.06);
}

.banner-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.banner-emoji {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.12), rgba(118, 75, 162, 0.12));
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.banner-info {
  display: flex;
  flex-direction: column;
}

.banner-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #303133;
}

.banner-count {
  font-size: 22rpx;
  color: #909399;
  margin-top: 2rpx;
}

.banner-desc {
  font-size: 24rpx;
  color: #909399;
  max-width: 280rpx;
  text-align: right;
  line-height: 1.4;
}

/* ===== 内容区域 ===== */
.content-area {
  margin: 0 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(102, 126, 234, 0.04);
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.content-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #303133;
}

.content-total {
  font-size: 22rpx;
  color: #909399;
}

/* ===== 内容卡片 ===== */
.item-list {
  display: flex;
  flex-direction: column;
}

.item-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.15s;
}

.item-card:last-child {
  border-bottom: none;
}

.item-card:active {
  background: rgba(102, 126, 234, 0.03);
  margin: 0 -12rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
  border-radius: 8rpx;
}

.item-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.item-type-badge {
  font-size: 20rpx;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.item-learned {
  font-size: 20rpx;
  color: #4ecdc4;
  font-weight: 500;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 6rpx;
  line-height: 1.4;
}

.item-desc {
  font-size: 24rpx;
  color: #909399;
  display: block;
  line-height: 1.5;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  flex: 1;
}

.item-tag {
  font-size: 20rpx;
  color: #909399;
  background: rgba(102, 126, 234, 0.06);
  padding: 3rpx 10rpx;
  border-radius: 4rpx;
}

.item-reading {
  font-size: 20rpx;
  color: #c0c4cc;
  flex-shrink: 0;
}

/* ===== 案例库 ===== */
.case-section {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(102, 126, 234, 0.04);
}

.case-list {
  display: flex;
  flex-direction: column;
}

.case-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.case-item:last-child {
  border-bottom: none;
}

.case-item:active {
  background: rgba(102, 126, 234, 0.03);
  margin: 0 -12rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
  border-radius: 8rpx;
}

.case-title {
  font-size: 28rpx;
  color: #303133;
}

.case-arrow {
  font-size: 28rpx;
  color: #667eea;
  font-weight: 600;
}

/* ===== 工具胶囊条 ===== */
.tools-strip {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(102, 126, 234, 0.04);
}

.tools-scroll {
  white-space: nowrap;
}

.tool-capsule {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.06), rgba(118, 75, 162, 0.06));
  border: 1rpx solid rgba(102, 126, 234, 0.12);
  border-radius: 30rpx;
  padding: 12rpx 22rpx;
  margin-right: 14rpx;
  transition: all 0.2s;
}

.tool-capsule:active {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15));
  transform: scale(0.97);
}

.tool-capsule-emoji {
  font-size: 28rpx;
}

.tool-capsule-name {
  font-size: 24rpx;
  color: #606266;
  font-weight: 500;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 28rpx 0 12rpx;
}

.load-more-text {
  display: inline-block;
  font-size: 26rpx;
  color: #667eea;
  font-weight: 600;
  background: rgba(102, 126, 234, 0.08);
  padding: 12rpx 48rpx;
  border-radius: 30rpx;
}

.no-more {
  text-align: center;
  padding: 20rpx 0 8rpx;
}

.no-more-text {
  font-size: 22rpx;
  color: #c0c4cc;
}

/* ===== 空状态 ===== */
.empty {
  text-align: center;
  padding: 60rpx 0 30rpx;
}

.empty-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #c0c4cc;
  display: block;
  margin-bottom: 4rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #dcdfe6;
  display: block;
}

/* ===== 底部安全区 ===== */
.bottom-safe {
  height: 40rpx;
}
