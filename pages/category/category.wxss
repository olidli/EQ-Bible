/* pages/category/category.wxss - 知识库首页：六模块平铺 · 主题色设计 */

.container {
  padding: 0;
  background: #f5f6fa;
  min-height: 100vh;
}

/* ===== 页面标题 ===== */
.page-header {
  padding: 32rpx 28rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
}
.page-header::after {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -60rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
}
.page-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  position: relative;
  z-index: 1;
}
.page-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  display: block;
  margin-top: 6rpx;
  position: relative;
  z-index: 1;
}

/* ===== 模块列表 ===== */
.module-list {
  padding: 24rpx 20rpx 0;
}

/* ===== 模块卡片 ===== */
.module-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 20rpx rgba(0,0,0,0.04);
  transition: box-shadow 0.2s;
}

/* ===== 模块头部 ===== */
.mod-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
}

.mod-header-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.mod-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.mod-emoji {
  font-size: 28rpx;
  display: block;
  line-height: 1;
}

.mod-info {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-left: 12rpx;
  gap: 10rpx;
}

.mod-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #303133;
  letter-spacing: 2rpx;
}

.mod-count {
  font-size: 22rpx;
  color: #c0c4cc;
}

.mod-header-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.mod-badge-num {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.mod-badge-unit {
  font-size: 18rpx;
  line-height: 1;
  margin-top: 2rpx;
  opacity: 0.8;
}

/* ===== 子目录列表 ===== */
.child-list {
  background: #fff;
}

/* ===== 子分类双列网格 ===== */
.child-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 20rpx 8rpx;
}

.child-grid-item {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  padding: 20rpx 18rpx;
  background: #f8f9fa;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  transition: background 0.15s, transform 0.1s;
  box-sizing: border-box;
}

.child-grid-item:active {
  background: #f0f2f5;
  transform: scale(0.98);
}

.child-grid-item.grid-active {
  background: rgba(102, 126, 234, 0.06);
}

.child-grid-main {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.child-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
  transition: background 0.2s;
}

.child-grid-name {
  font-size: 28rpx;
  font-weight: 500;
  transition: color 0.2s;
  line-height: 1.3;
}

.child-grid-count {
  font-size: 22rpx;
  color: #c0c4cc;
  padding-left: 20rpx;
}

/* ===== 子目录展开的内容区 ===== */
.child-items {
  background: #f5f6fa;
  margin: 0;
  padding: 8rpx 28rpx 16rpx;
  border-top: 1rpx solid rgba(0,0,0,0.04);
}

/* ===== 内容卡片 ===== */
.item-card {
  padding: 18rpx 16rpx;
  background: #fff;
  border-radius: 14rpx;
  margin-top: 12rpx;
  box-shadow: 0 1rpx 6rpx rgba(0,0,0,0.04);
  transition: box-shadow 0.15s, transform 0.15s;
}

.item-card:active {
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.1);
  transform: translateY(-1rpx);
}

.item-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.item-type-badge {
  font-size: 20rpx;
  color: #fff;
  padding: 3rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.item-learned {
  font-size: 20rpx;
  color: #4ecdc4;
  font-weight: 500;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 6rpx;
  line-height: 1.45;
}

.item-desc {
  font-size: 24rpx;
  color: #aaa;
  display: block;
  line-height: 1.5;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  flex: 1;
}

.item-tag {
  font-size: 20rpx;
  color: #909399;
  background: #f0f2f5;
  padding: 3rpx 10rpx;
  border-radius: 4rpx;
}

.item-reading {
  font-size: 20rpx;
  color: #c0c4cc;
  flex-shrink: 0;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 20rpx 0 8rpx;
}

.load-more-text {
  display: inline-block;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 50rpx;
  border-radius: 30rpx;
}

.no-more {
  text-align: center;
  padding: 18rpx 0 6rpx;
}

.no-more-text {
  font-size: 22rpx;
  color: #d0d0d0;
}

/* ===== 底部安全区 ===== */
.bottom-safe {
  height: 40rpx;
}

/* ===== 学习进度卡片 ===== */
.today-card {
  margin: 0 24rpx 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 28rpx 28rpx 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
  color: #fff;
}
.today-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.today-left {
  display: flex;
  flex-direction: column;
}
.today-greeting {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}
.today-stats {
  font-size: 22rpx;
  opacity: 0.85;
}
.today-pct {
  display: flex;
  align-items: flex-end;
}
.today-pct-num {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
}
.today-pct-sym {
  font-size: 22rpx;
  opacity: 0.8;
  margin-bottom: 6rpx;
  margin-left: 4rpx;
}
.today-progress-wrap {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}
.today-progress-fill {
  height: 100%;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 4rpx;
  transition: width 0.6s ease;
}
