/* pages/category/category.wxss - 分类页渐变美化版 */

.container {
  padding: 0 0 40rpx;
  background: linear-gradient(180deg, #f8f9ff 0%, #f0f2ff 50%, #f5f5f5 100%);
  min-height: 100vh;
}

/* ===== 二级导航 - 玻璃态效果 ===== */
.sub-nav {
  white-space: nowrap;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(102, 126, 234, 0.08);
  position: sticky;
  top: 0;
  z-index: 100;
}

.sub-nav-item {
  display: inline-block;
  font-size: 26rpx;
  color: #606266;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  margin-right: 12rpx;
  transition: all 0.3s ease;
  background: rgba(102, 126, 234, 0.05);
}

.sub-nav-item.active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

/* ===== 模块介绍 - 渐变卡片 ===== */
.module-intro {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  background-size: 200% 200%;
  animation: bgShift 6s ease infinite;
  margin: 20rpx 24rpx 0;
  padding: 32rpx 28rpx;
  border-radius: 20rpx;
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.25);
}

@keyframes bgShift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.module-title {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.module-desc {
  font-size: 26rpx;
  opacity: 0.95;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.module-tools {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.module-tool-tag {
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10rpx);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* ===== 内容列表 ===== */
.content-list {
  padding: 20rpx 24rpx;
}

.section {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.08);
  border: 1rpx solid rgba(102, 126, 234, 0.08);
  position: relative;
  overflow: hidden;
}

.section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-count {
  font-size: 24rpx;
  color: #909399;
}

/* ===== 工具卡片 - 渐变边框效果 ===== */
.tool-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.tool-card {
  width: calc(50% - 8rpx);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05), rgba(118, 75, 162, 0.05));
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
  transition: all 0.3s ease;
}

.tool-card:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
}

.tool-card-emoji {
  font-size: 40rpx;
  display: block;
  margin-bottom: 8rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(118, 75, 162, 0.15));
  padding: 12rpx;
  border-radius: 12rpx;
}

.tool-card-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 4rpx;
}

.tool-card-desc {
  font-size: 22rpx;
  color: #909399;
}

/* ===== 内容卡片 - 渐变标签 ===== */
.item-list {
  display: flex;
  flex-direction: column;
}

.item-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.08);
  transition: all 0.2s;
  border-radius: 8rpx;
}

.item-card:last-child {
  border-bottom: none;
}

.item-card:active {
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.05), transparent);
  padding-left: 12rpx;
}

.item-type-badge {
  display: inline-block;
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea, #764ba2);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.item-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.item-tag {
  font-size: 22rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  color: #667eea;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.15);
}

/* ===== 案例列表 ===== */
.case-list {
  display: flex;
  flex-direction: column;
}

.case-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(102, 126, 234, 0.08);
  transition: all 0.2s;
  border-radius: 8rpx;
}

.case-item:last-child {
  border-bottom: none;
}

.case-item:active {
  background: linear-gradient(90deg, rgba(102, 126, 234, 0.05), transparent);
  padding-left: 12rpx;
}

.case-title {
  font-size: 28rpx;
  color: #303133;
}

.case-arrow {
  font-size: 32rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ===== 空状态 ===== */
.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #C0C4CC;
  font-size: 28rpx;
}
